NODE_ENV=development

# Read-write primary (postgresql-cluster-rw) — used for all writes
PODIUM_DATABASE_URL_RW=postgresql://podium:podium@postgresql-cluster-rw.postgresql.svc.cluster.local:5432/podium
# Read-only hot standby (postgresql-cluster-ro) — used for most reads
PODIUM_DATABASE_URL_RO=postgresql://podium:podium@postgresql-cluster-ro.postgresql.svc.cluster.local:5432/podium
# Any replica, may lag (postgresql-cluster-r) — used for leaderboard / public listings
PODIUM_DATABASE_URL_R=postgresql://podium:podium@postgresql-cluster-r.postgresql.svc.cluster.local:5432/podium

PODIUM_JWT_SECRET=your-secret-key-change-in-production
PODIUM_JWT_ALGORITHM=HS256
PODIUM_JWT_EXPIRE_MINUTES=2880

PODIUM_PRODUCTION_URL=http://localhost:3000

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=podium-screenshots
R2_PUBLIC_URL=

PODIUM_ACTIVE_EVENT_SERIES=
PODIUM_ENABLE_TEST_ENDPOINTS=false

KAFKA_BROKER=localhost:9092

GATEWAY_PORT=3000
AUTH_SERVICE_URL=http://127.0.0.1:8001
EVENTS_SERVICE_URL=http://127.0.0.1:8002
PROJECTS_SERVICE_URL=http://127.0.0.1:8003
FRONTEND_URL=http://127.0.0.1:5173

PUBLIC_API_URL=http://localhost:3000/api