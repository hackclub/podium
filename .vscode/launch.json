{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "frontend",
      "type": "node-terminal",
      "request": "launch",
      "command": "bun run dev",
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "All Services",
      "type": "node-terminal",
      "request": "launch",
      "command": "./dev.sh",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Gateway",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm --filter podium-gateway dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Auth Service",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm --filter podium-auth-service start:dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Events Service",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm --filter podium-events-service start:dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Projects Service",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm --filter podium-projects-service start:dev",
      "cwd": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "dev",
      "configurations": ["All Services"]
    }
  ]
}
