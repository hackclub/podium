{
  "version": "0.2.0",
  "inputs": [
    {
      "id": "doppler_environment",
      // To manaully run a command with doppler (backend): doppler run --config prd -- uv run ...
      "description": "Select Doppler environment",
      "type": "pickString",
      "options": [
        {
          "label": "Development",
          "value": "dev"
        },
        {
          "label": "Production",
          "value": "prd_local" // Local production: sets turnstile to test key to approve all reqs, set loops key to an empty string to disable email sending, and set PODIUM_PRODUCTION_URL to http://localhost:5173 
        }
      ],
      "default": "dev"
    }
  ],
  "configurations": [
    {
      // To run bun dev in prod mode:
      // MacOS/Linux: NODE_ENV=production bun run dev
      // Windows (powershell): $env:NODE_ENV="production"; bun run dev; $env:NODE_ENV=""
      "name": "frontend",
      "type": "node-terminal",
      "request": "launch",
      "command": "bun run dev",
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["podium.main:app", "--reload"],
      "env": {
        "DOPPLER_ENV": "1",
        "DOPPLER_CONFIG": "${input:doppler_environment}"
      },
      "cwd": "${workspaceFolder}/backend",
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "dev",
      "configurations": ["frontend", "FastAPI"]
    }
  ]
}
